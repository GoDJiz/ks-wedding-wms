# ══════════════════════════════════════════════════════════════════
# Wedding Management System — Environment Variables
# Copy this file to .env.local for local dev. For Vercel, add the same
# keys in Project Settings → Environment Variables (see docs/DEPLOYMENT.md §4.2).
# ALL variables below are Vercel/Next.js environment variables — this app
# has no Supabase Edge Functions in active use (see docs/SIGNIFICANT_FINDINGS.md,
# Milestone 4 entry, for the pivot away from that architecture).
# ══════════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────────
# Where to find these: Supabase Dashboard → Project Settings → API

# Your project's API URL. Safe to expose to the browser (NEXT_PUBLIC_ prefix required).
# Example: https://abcdefghijk.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" / public API key. Safe to expose to the browser — Row Level
# Security (RLS) is what actually protects data, not secrecy of this key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The "service_role" key. FULL ADMIN ACCESS — bypasses RLS entirely.
# NEVER prefix with NEXT_PUBLIC_, never send to the browser, never commit it.
# Used server-side only, exclusively by src/infrastructure/supabase/serviceRole.ts,
# which is imported only by the two external-trigger Route Handlers
# (/api/sync/guests, /api/notifications/payment-reminders) — those callers
# have no user session to authenticate with, so they use this instead.
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth ─────────────────────────────────────────────────
# No env vars needed here — the Google Client ID/Secret are entered directly
# into the Supabase Dashboard (Authentication → Providers → Google), not here.
# See docs/DEPLOYMENT.md §3.

# ── LINE Messaging API ───────────────────────────────────────────
# Where to find this: LINE Developers Console → your Messaging API channel
# → Channel access token (long-lived).
#
# Set this as a VERCEL environment variable (Project Settings → Environment
# Variables), NOT a Supabase secret — it's read via process.env by Next.js
# Route Handlers and Server Actions (src/shared/notifications/lineClient.ts,
# src/features/system-health/infrastructure/healthChecks.ts), not by any
# Supabase Edge Function.
#
# Recipients (who actually gets notified) are NOT an env var — they're
# managed in-app at Settings → Notifications (notification_recipients
# table), so you can add/remove people without redeploying.
LINE_CHANNEL_ACCESS_TOKEN=

# ── External Trigger Shared Secret ────────────────────────────────
# A password-like string YOU make up (e.g. `openssl rand -hex 16`). Set as
# a VERCEL environment variable. Authenticates two external-trigger Route
# Handlers that have no user session (so RLS/login can't protect them):
#   - POST /api/sync/guests               (scheduled guest sync)
#   - POST /api/notifications/payment-reminders  (scheduled payment reminders)
# Both are meant to be pinged by a Google Apps Script time-driven trigger
# (see docs/DEPLOYMENT.md §6) — or any other scheduler/curl for testing.
# Must match exactly what you configure in the Apps Script.
SHEET_SYNC_SHARED_SECRET=
