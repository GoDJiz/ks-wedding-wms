# ══════════════════════════════════════════════════════════════════
# Wedding Management System — Environment Variables
# Copy this file to .env.local for local dev. For Vercel, add the same
# keys in Project Settings → Environment Variables (see docs/DEPLOYMENT.md §7).
# ══════════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────────
# Where to find these: Supabase Dashboard → Project Settings → API

# Your project's API URL. Safe to expose to the browser (NEXT_PUBLIC_ prefix required).
# Example: https://abcdefghijk.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" / public API key. Safe to expose to the browser — Row Level
# Security (RLS) is what actually protects data, not secrecy of this key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The "service_role" key. FULL ADMIN ACCESS — bypasses RLS entirely.
# NEVER prefix with NEXT_PUBLIC_, never send to the browser, never commit it.
# Only used server-side (Edge Functions, admin scripts like backup export).
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth ─────────────────────────────────────────────────
# No env vars needed here — the Google Client ID/Secret are entered directly
# into the Supabase Dashboard (Authentication → Providers → Google), not here.
# See docs/DEPLOYMENT.md §4.

# ── LINE Messaging API ───────────────────────────────────────────
# Where to find these: LINE Developers Console → your Messaging API channel

# Long-lived channel access token used to push messages. Set this as a
# SUPABASE EDGE FUNCTION SECRET (supabase secrets set ...), not here —
# Edge Functions run outside Next.js and don't read .env.local.
# Listed here only as a reminder of what the value is / where it's used.
LINE_CHANNEL_ACCESS_TOKEN=

# Your own LINE userId, used only for the Milestone 0 test push.
# Set as an Edge Function secret, same as above.
LINE_TEST_USER_ID=

# ── Google Sheets Sync ───────────────────────────────────────────
# A password-like string YOU make up. Must match exactly in two places:
# 1. This value here (set as an Edge Function secret)
# 2. The SHARED_SECRET constant inside integrations/google-apps-script/sync.gs
# Purpose: lets the Edge Function verify a request really came from your
# Apps Script and not a random internet caller (Apps Script calls are
# otherwise unauthenticated).
SHEET_SYNC_SHARED_SECRET=
